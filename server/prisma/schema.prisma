generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  avatar        String?
  role          String    @default("user")
  balance       Float     @default(0)
  trustScore    Int       @default(0)
  status        String    @default("active")
  phone         String?
  userType      String    @default("personal")
  verified      Boolean   @default(false)
  companyName   String?
  companyId     String?
  idCard        String?
  subscription  String    @default("free")
  subscriptionExpiresAt DateTime?
  lastCheckIn   DateTime?
  checkInStreak Int       @default(0)
  totalCheckIns Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  agents        Agent[]
  tasks         Task[]
  conversations Conversation[]
  agentGroups   AgentGroup[]
  knowledgeBases KnowledgeBase[]
  notifications Notification[]
  pointTransactions PointTransaction[]
  
  @@map("users")
}

model Agent {
  id             String     @id @default(cuid())
  name           String
  avatar         String
  title          String?
  description    String?
  systemPrompt   String
  ownerId        String
  verified       Boolean    @default(false)
  trustScore     Int        @default(0)
  status         String     @default("online")
  category       String
  tags           String
  rating         Float      @default(0)
  tasksCompleted Int        @default(0)
  totalEarnings  Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  owner          User       @relation(fields: [ownerId], references: [id])
  tasks          Task[]
  bids           Bid[]
  conversations  Conversation[]
  agentSkills    AgentSkill[]
  groupMembers   GroupMember[]
  
  @@map("agents")
}

model AgentSkill {
  id        String   @id @default(cuid())
  agentId   String
  skillName String
  level     Int      @default(0)
  usageCount Int     @default(0)
  
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@map("agent_skills")
}

model AgentGroup {
  id          String       @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  owner       User         @relation(fields: [ownerId], references: [id])
  members     GroupMember[]
  
  @@map("agent_groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  agentId   String
  role      String   @default("member")
  
  group     AgentGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  agent     Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@unique([groupId, agentId])
  @@map("group_members")
}

model Task {
  id              String         @id @default(cuid())
  title           String
  description     String
  budget          Float
  status          String         @default("pending")
  category        String
  tags            String
  creatorId       String
  agentId         String?
  deadline        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  creator         User           @relation(fields: [creatorId], references: [id])
  agent           Agent?         @relation(fields: [agentId], references: [id])
  bids            Bid[]
  transaction     Transaction?
  
  @@map("tasks")
}

model Bid {
  id          String   @id @default(cuid())
  taskId      String
  agentId     String
  bidAmount   Float
  proposal    String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent       Agent    @relation(fields: [agentId], references: [id])
  
  @@map("bids")
}

model Transaction {
  id              String   @id @default(cuid())
  taskId          String   @unique
  amount          Float
  status          String   @default("pending")
  blockchainHash  String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@map("transactions")
}

model ModelConfig {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String
  apiKey      String
  baseUrl     String
  enabled     Boolean  @default(true)
  modelName   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("model_configs")
}

model Conversation {
  id            String    @id @default(cuid())
  agentId       String
  userId        String
  messages      String
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  agent         Agent     @relation(fields: [agentId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
  
  @@map("conversations")
}

model KnowledgeBase {
  id          String    @id @default(cuid())
  title       String
  fileName    String
  filePath    String
  fileSize    Int
  fileType    String
  content     String
  description String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id])
  
  @@map("knowledge_bases")
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  payload     String
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  
  @@map("notifications")
}

model PointTransaction {
  id          String    @id @default(cuid())
  userId      String
  type        String
  amount      Float
  balanceAfter Float
  description String
  category    String
  referenceId String?
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  
  @@map("point_transactions")
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  priceMonthly  Float
  priceYearly   Float
  pointsMonthly Int
  description   String?
  features      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("subscription_plans")
}

model UserSubscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  planId        String
  status        String   @default("active")
  startDate     DateTime @default(now())
  endDate       DateTime
  autoRenew     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("user_subscriptions")
}