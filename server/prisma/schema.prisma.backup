generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  avatar        String?
  role          String    @default("user")
  balance       Float     @default(0)
  trustScore    Int       @default(0)
  status        String    @default("active")
  phone         String?
  userType      String    @default("personal")
  verified      Boolean   @default(false)
  companyName   String?
  companyId     String?
  idCard        String?
  subscription  String    @default("free")
  subscriptionExpiresAt DateTime?
  lastCheckIn   DateTime?
  checkInStreak Int       @default(0)
  totalCheckIns Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  agents        Agent[]
  tasks         Task[]
  conversations Conversation[]
  agentGroups   AgentGroup[]
  knowledgeBases KnowledgeBase[]
  notifications Notification[]
  pointTransactions PointTransaction[]

  // 积分相关关系
  creditAccount     CreditAccount?
  creditTransactions CreditTransaction[]

  @@map("users")
}

model Agent {
  id             String     @id @default(cuid())
  name           String
  avatar         String
  title          String?
  description    String?
  systemPrompt   String
  ownerId        String
  verified       Boolean    @default(false)
  trustScore     Int        @default(0)
  status         String     @default("online")
  category       String
  tags           String
  rating         Float      @default(0)
  tasksCompleted Int        @default(0)
  totalEarnings  Float      @default(0)
  modelName      String     @default("deepseek-chat")
  temperature    Float      @default(0.7)
  maxTokens      Int        @default(4096)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  owner          User       @relation(fields: [ownerId], references: [id])
  tasks          Task[]
  bids           Bid[]
  conversations  Conversation[]
  agentSkills    AgentSkill[]
  groupMembers   GroupMember[]
  agentTools     AgentTool[]
  agentKnowledge AgentKnowledge[]
  taskExecutions TaskExecution[]
  
  @@map("agents")
}

model AgentSkill {
  id        String   @id @default(cuid())
  agentId   String
  skillName String
  level     Int      @default(0)
  usageCount Int     @default(0)
  
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@map("agent_skills")
}

model AgentTool {
  id        String   @id @default(cuid())
  agentId   String
  toolName  String
  enabled   Boolean  @default(true)
  
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@map("agent_tools")
}

model AgentGroup {
  id          String       @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  owner       User         @relation(fields: [ownerId], references: [id])
  members     GroupMember[]
  
  @@map("agent_groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  agentId   String
  role      String   @default("member")
  
  group     AgentGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  agent     Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@unique([groupId, agentId])
  @@map("group_members")
}

model Task {
  id              String         @id @default(cuid())
  title           String
  description     String
  budget          Float
  status          String         @default("pending")
  category        String
  tags            String
  creatorId       String
  agentId         String?
  deadline        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  creator         User           @relation(fields: [creatorId], references: [id])
  agent           Agent?         @relation(fields: [agentId], references: [id])
  bids            Bid[]
  transaction     Transaction?
  taskExecutions  TaskExecution[]

  @@map("tasks")
}

model Bid {
  id          String   @id @default(cuid())
  taskId      String
  agentId     String
  bidAmount   Float
  proposal    String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent       Agent    @relation(fields: [agentId], references: [id])
  
  @@map("bids")
}

model Transaction {
  id              String   @id @default(cuid())
  taskId          String   @unique
  amount          Float
  status          String   @default("pending")
  blockchainHash  String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@map("transactions")
}

model ModelConfig {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String
  apiKey      String
  baseUrl     String
  enabled     Boolean  @default(true)
  modelName   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("model_configs")
}

model Conversation {
  id            String    @id @default(cuid())
  agentId       String
  userId        String
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  agent         Agent     @relation(fields: [agentId], references: [id])
  user          User      @relation(fields: [userId], references: [id])
  messages      Message[]
  
  @@map("conversations")
}

model Message {
  id            String    @id @default(cuid())
  conversationId String
  role          String    @default("user")
  content       String
  toolCalls     String?
  toolResults   String?
  metadata      String?
  inputTokens   Int?
  outputTokens  Int?
  creditsConsumed Int     @default(0)
  createdAt     DateTime  @default(now())

  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@map("messages")
}

model KnowledgeBase {
  id          String    @id @default(cuid())
  title       String
  fileName    String
  filePath    String
  fileSize    Int
  fileType    String
  content     String
  description String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id])
  agentKb     AgentKnowledge[]
  
  @@map("knowledge_bases")
}

model AgentKnowledge {
  id            String    @id @default(cuid())
  agentId       String
  knowledgeId   String
  createdAt     DateTime  @default(now())
  
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  
  @@unique([agentId, knowledgeId])
  @@map("agent_knowledge")
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  payload     String
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  
  @@map("notifications")
}

model PointTransaction {
  id          String    @id @default(cuid())
  userId      String
  type        String
  amount      Float
  balanceAfter Float
  description String
  category    String
  referenceId String?
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  
  @@map("point_transactions")
}

model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  priceMonthly  Float
  priceYearly   Float
  pointsMonthly Int
  description   String?
  features      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("subscription_plans")
}

model UserSubscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  planId        String
  status        String   @default("active")
  startDate     DateTime @default(now())
  endDate       DateTime
  autoRenew     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_subscriptions")
}

model TaskExecution {
  id            String    @id @default(cuid())
  taskId        String
  agentId       String
  status        String    @default("assigned")
  step          String    @default("accepted")
  progress      Int       @default(0)
  input         String?
  output        String?
  result        String?
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("task_executions")
}

// ==================== 积分系统 ====================

model CreditAccount {
  id               String    @id @default(cuid())
  userId           String    @unique
  totalCredits     Int       @default(0)
  availableCredits Int       @default(0)
  frozenCredits    Int       @default(0)
  spentCredits     Int       @default(0)
  lifetimeSpent    Int       @default(0)

  monthlyQuota     Int       @default(0)
  monthlyUsed      Int       @default(0)
  quotaResetAt     DateTime  @default(now())

  level            Int       @default(1)
  totalPurchased   Int       @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_accounts")
}

model CreditTransaction {
  id             String    @id @default(cuid())
  userId         String
  type           String
  amount         Int
  balanceBefore  Int
  balanceAfter   Int
  category       String
  description    String
  referenceId    String?

  serviceType    String?
  modelName      String?
  inputTokens    Int?
  outputTokens   Int?

  status         String    @default("completed")
  expiresAt      DateTime?

  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([category, createdAt])
  @@map("credit_transactions")
}

model ConsumptionRule {
  id               String    @id @default(cuid())
  name             String
  serviceType      String    @unique
  baseCredits      Int       @default(0)
  perTokenCredits  Float?
  perMinuteCredits Int?

  dailyLimit       Int?
  monthlyLimit     Int?
  perRequestMin    Int?
  perRequestMax    Int?

  description      String?
  example          String?

  isActive         Boolean   @default(true)
  priority         Int       @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("consumption_rules")
}

model ServiceUsageLog {
  id               String    @id @default(cuid())
  userId           String
  sessionId        String?

  serviceType      String
  action           String

  creditsConsumed  Int       @default(0)

  modelName        String?
  inputTokens      Int?
  outputTokens     Int?
  duration         Int?

  referenceId      String?
  referenceType    String?

  status           String    @default("success")

  createdAt        DateTime  @default(now())

  @@index([userId, serviceType, createdAt])
  @@index([serviceType, createdAt])
  @@map("service_usage_logs")
}

model CreditLevel {
  id               String    @id @default(cuid())
  level            Int       @unique
  name             String
  displayName      String
  lifetimeSpent    Int
  discountRate     Float     @default(0)
  bonusRate        Float     @default(0)
  priorityBoost    Int       @default(0)
  exclusiveFeatures String?
  isActive         Boolean   @default(true)

  @@map("credit_levels")
}